# Environment profile
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Primary infrastructure
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/postgres
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Admission and task behavior
TASK_COST=10
MAX_CONCURRENT=3
AUTH_CACHE_TTL_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400
TASK_RESULT_TTL_SECONDS=86400
PENDING_MARKER_TTL_SECONDS=120
ORPHAN_MARKER_TIMEOUT_SECONDS=60
TASK_STUCK_TIMEOUT_SECONDS=300
REAPER_INTERVAL_SECONDS=30
CELERY_QUEUE_NAME=celery

# Worker runtime
WORKER_METRICS_PORT=9100
DB_POOL_COMMAND_TIMEOUT_SECONDS=0.1
DB_STATEMENT_TIMEOUT_MS=50
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=500
REDIS_SOCKET_TIMEOUT_SECONDS=0.05
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.05
WORKER_DB_TIMEOUT_SECONDS=5.0
WORKER_LOOP_TASK_TIMEOUT_SECONDS=180.0
WORKER_LOOP_BOOTSTRAP_TIMEOUT_SECONDS=30.0
WORKER_LOOP_SHUTDOWN_TIMEOUT_SECONDS=10.0

# Readiness thresholds
READINESS_POSTGRES_TIMEOUT_SECONDS=1.0
READINESS_REDIS_TIMEOUT_SECONDS=1.0
READINESS_CELERY_TIMEOUT_SECONDS=1.0

# Dev-only reproducibility keys (never use in production)
ADMIN_API_KEY=e1138140-6c35-49b6-b723-ba8d609d8eb5
ALICE_API_KEY=586f0ef6-e655-4413-ab08-a481db150389
BOB_API_KEY=c9169bc2-2980-4155-be29-442ffc44ce64

# Environment profile
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Primary infrastructure
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/postgres
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
DSN=postgres://postgres:postgres@postgres:5432/postgres?sslmode=disable
URLS_SELF_ISSUER=http://hydra:4444/
SECRETS_SYSTEM=["youReallyNeedToChangeThis","youAlsoNeedToChangeThis"]
OAUTH2_ACCESS_TOKEN_STRATEGY=jwt
HYDRA_PUBLIC_URL=http://hydra:4444
HYDRA_ADMIN_URL=http://hydra:4445
HYDRA_ISSUER=http://hydra:4444/
HYDRA_JWKS_URL=http://hydra:4444/.well-known/jwks.json
HYDRA_JWKS_CACHE_TTL_SECONDS=300.0
# Optional JWT audience hardening (leave empty to disable strict aud validation).
# HYDRA_EXPECTED_AUDIENCE=solution2-api
# Hydra log redaction override for local debugging (do not enable in production).
LOG_LEAK_SENSITIVE_VALUES=true
# Optional tracing profile (enable with: OTEL_ENABLED=true docker compose --profile tracing up -d)
OTEL_ENABLED=false
OTEL_SERVICE_NAMESPACE:-metered-compute
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_EXPORT_TIMEOUT_SECONDS=3.0
OTEL_SAMPLER_RATIO=1.0

# Admission and task behavior
TASK_COST=10
MAX_CONCURRENT=3
AUTH_CACHE_TTL_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400
TASK_RESULT_TTL_SECONDS=86400
PENDING_MARKER_TTL_SECONDS=120
RESERVATION_TTL_SECONDS=300
WATCHDOG_INTERVAL_SECONDS=30.0
WATCHDOG_ERROR_BACKOFF_SECONDS=1.0
WATCHDOG_SCAN_COUNT=100
WATCHDOG_METRICS_PORT=9400
WEBHOOK_ENABLED=true
WEBHOOK_QUEUE_KEY=webhook:queue
WEBHOOK_SCHEDULED_KEY=webhook:scheduled
WEBHOOK_DLQ_KEY=webhook:dlq
WEBHOOK_DISPATCH_BATCH_SIZE=100
WEBHOOK_DISPATCHER_POLL_TIMEOUT_SECONDS=2
WEBHOOK_DELIVERY_TIMEOUT_SECONDS=3.0
WEBHOOK_DISPATCH_ERROR_BACKOFF_SECONDS=1.0
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_INITIAL_BACKOFF_SECONDS=1.0
WEBHOOK_BACKOFF_MULTIPLIER=2.0
WEBHOOK_MAX_BACKOFF_SECONDS=60.0
REDIS_TASK_STATE_TTL_SECONDS=86400
WORKER_HEARTBEAT_KEY=workers:worker:last_seen
WORKER_HEARTBEAT_TTL_SECONDS=30
WORKER_ERROR_BACKOFF_SECONDS=1.0

# Outbox relay
OUTBOX_RELAY_BATCH_SIZE=100
OUTBOX_RELAY_EMPTY_BACKOFF_SECONDS=0.05
OUTBOX_RELAY_ERROR_BACKOFF_SECONDS=1.0
OUTBOX_RELAY_CONNECT_TIMEOUT_SECONDS=3.0
OUTBOX_RELAY_PURGE_INTERVAL_SECONDS=60.0
OUTBOX_RELAY_PURGE_RETENTION_SECONDS=604800
OUTBOX_RELAY_PURGE_BATCH_SIZE=500
OUTBOX_RELAY_METRICS_PORT=9200

# Worker runtime
WORKER_METRICS_PORT=9100
WEBHOOK_METRICS_PORT=9300
WORKER_DB_TIMEOUT_SECONDS=5.0
WORKER_LOOP_TASK_TIMEOUT_SECONDS=180.0
WORKER_LOOP_BOOTSTRAP_TIMEOUT_SECONDS=30.0
WORKER_LOOP_SHUTDOWN_TIMEOUT_SECONDS=10.0

# Readiness thresholds
READINESS_POSTGRES_TIMEOUT_SECONDS=1.0
READINESS_REDIS_TIMEOUT_SECONDS=1.0
READINESS_WORKER_TIMEOUT_SECONDS=1.0
DB_STATEMENT_TIMEOUT_MS=50
DB_STATEMENT_TIMEOUT_BATCH_MS=2000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=500
DB_POOL_COMMAND_TIMEOUT_SECONDS=0.1
DB_POOL_MAX_INACTIVE_CONNECTION_LIFETIME_SECONDS=300.0
REDIS_SOCKET_TIMEOUT_SECONDS=0.05
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.05

# Dev-only reproducibility keys (never use in production)
ADMIN_API_KEY=e1138140-6c35-49b6-b723-ba8d609d8eb5
ALICE_API_KEY=586f0ef6-e655-4413-ab08-a481db150389
BOB_API_KEY=c9169bc2-2980-4155-be29-442ffc44ce64

# OAuth clients for local reproducibility (dev only)
OAUTH_ADMIN_CLIENT_ID=solution2-admin
OAUTH_ADMIN_CLIENT_SECRET=solution2-admin-secret
OAUTH_USER1_CLIENT_ID=solution2-user1
OAUTH_USER1_CLIENT_SECRET=solution2-user1-secret
OAUTH_USER2_CLIENT_ID=solution2-user2
OAUTH_USER2_CLIENT_SECRET=solution2-user2-secret
OAUTH_ADMIN_TIER=enterprise
OAUTH_USER1_TIER=pro
OAUTH_USER2_TIER=free
OAUTH_ADMIN_USER_ID=5ba7f2f8-24be-448a-9552-3af6e06e8898
OAUTH_USER1_USER_ID=47b47338-5355-4edc-860b-846d71a2a75a
OAUTH_USER2_USER_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
# OAuth token endpoint throttle (fixed window; Redis-backed)
OAUTH_TOKEN_RATE_LIMIT_ENABLED=true
OAUTH_TOKEN_RATE_LIMIT_WINDOW_SECONDS=60
OAUTH_TOKEN_RATE_LIMIT_MAX_REQUESTS=120
REVOCATION_BUCKET_TTL_SECONDS=129600
